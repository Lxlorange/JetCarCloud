APP_NAME=JetCarCloud
HOST=0.0.0.0
PORT=8000
YOLO_BACKEND=auto
YOLO_MODEL_PATH=
YOLOV5_REPO_PATH=
YOLO_DEVICE=cpu
YOLO_CONFIDENCE=0.25
YOLO_IMAGE_SIZE=640
APP_RESULT_HISTORY=1
EDGE_FRAME_URL=
VIDEO_DEFAULT_WIDTH=640
VIDEO_DEFAULT_HEIGHT=640
VIDEO_DEFAULT_FPS=2.0
VIDEO_CAPTURE_TIMEOUT_MS=5000
VIDEO_PUSH_MIN_INTERVAL_MS=200
ALGORITHM_MIN_INTERVAL_MS=1000
ALGORITHM_MAX_CONCURRENT_TASKS=2
ALGORITHM_CATALOG_PATH=algorithms.json
ALGORITHM_WORK_DIR=.jetcar_algorithm_runs
DOCKER_EXECUTABLE=docker
DEBUG_DUMP_ENABLED=true
DEBUG_DUMP_DIR=.jetcar_debug
DEBUG_SAVE_IMAGES=true
DEBUG_SAVE_ALGORITHM_OUTPUTS=true
DEBUG_DUMP_SKIPPED_FRAMES=false
