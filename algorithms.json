{
  "algorithms": {
    "yolov5-similarity": {
      "name": "YOLOv5 Similarity",
      "runner": "local",
      "image": "",
      "inputs": ["frame.jpg", "request.json"],
      "outputs": ["result.json", "annotated.jpg"],
      "timeout_seconds": 60,
      "enabled": true,
      "metadata": {
        "task": "similarity",
        "model_path": "models/yolov5-similarity/yolov5s.pt",
        "template_path": "models/yolov5-similarity/target.jpg",
        "threshold": 0.70
      }
    },
    "yolov5-manhole-detect": {
      "name": "YOLOv5 Manhole Detection",
      "runner": "local",
      "image": "",
      "inputs": ["frame.jpg", "request.json"],
      "outputs": ["result.json", "annotated.jpg"],
      "timeout_seconds": 60,
      "enabled": true,
      "metadata": {
        "task": "manhole_detection",
        "model_path": "models/yolov5-manhole/Manhole_model.pt",
        "source_dir": "models/yolov5-manhole/src",
        "img_size": 512,
        "conf_threshold": 0.18,
        "iou_threshold": 0.45,
        "max_det": 50,
        "device": ""
      }
    },
    "yolov8-road-damage": {
      "name": "YOLOv8 Road Damage Detection",
      "runner": "local",
      "image": "",
      "inputs": ["frame.jpg", "request.json"],
      "outputs": ["result.json", "annotated.jpg"],
      "timeout_seconds": 60,
      "enabled": true,
      "metadata": {
        "task": "road_damage_detection",
        "model_path": "models/yolov8-road-damage/YOLOv8_Small_2nd_Model.pt",
        "imgsz": 512,
        "conf": 0.16,
        "iou": 0.45,
        "max_det": 50,
        "device": "auto"
      }
    }
  }
}
